# Public copy ships without BEA key. Add your own token to enable BEA feed.
BEA_TOKEN=your_token_here
# Optional override:
# BEA_REST_BASE=https://www.bleedingedgealpha.net/api/v1

# Polling / source configuration
BEA_POLL_MS=1200
BEA_SYMBOLS=BTC-USD
TAPE_REORDER_BUFFER_MS=180
TAPE_MAX_ADAPTIVE_REORDER_MS=900
TAPE_MAX_NOTIONAL_USD=25000000
TAPE_MAX_TRADE_AGE_MS=180000
TAPE_MAX_FUTURE_SKEW_MS=2500
# In production, keep 0 so process env wins over .env file.
TAPE_DOTENV_OVERRIDE=0

# Public free connectors (BTC only by default)
ENABLE_BINANCE_PERPS=1
ENABLE_BINANCE_SPOT=1
ENABLE_BYBIT_LINEAR=1
ENABLE_BYBIT_SPOT=1
ENABLE_OKX_SWAP=1
ENABLE_OKX_SPOT=1
ENABLE_COINBASE=1
ENABLE_KRAKEN=1
ENABLE_BITSTAMP=1
ENABLE_BITMEX=1
ENABLE_DERIBIT=1
ENABLE_HYPERLIQUID=1
ENABLE_BITFINEX=1
# BTCC connector is experimental because endpoint/symbol behavior varies.
ENABLE_BTCC=0
# Example only; set your live BTCC WS endpoint when enabling BTCC.
BTCC_WS_URL=
