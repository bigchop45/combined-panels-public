APP_SYMBOL=BTC-USD
APP_DOTENV_OVERRIDE=0

# Public copy ships without BEA key. Add your own token to enable BEA feed.
BEA_TOKEN=your_token_here
BEA_REST_BASE=https://www.bleedingedgealpha.net/api/v1
BEA_POLL_MS=1200

ENABLE_BEA=1
ENABLE_BINANCE_PERPS=1
ENABLE_BYBIT_LINEAR=1
ENABLE_OKX_SWAP=1
ENABLE_HYPERLIQUID=1
ENABLE_BITFINEX=1

APP_REORDER_BUFFER_MS=180
APP_MAX_ADAPTIVE_REORDER_MS=900
APP_MAX_NOTIONAL_USD=25000000
APP_MAX_TRADE_AGE_MS=180000
APP_MAX_FUTURE_SKEW_MS=2500

ABS_WINDOW_MS=2500
ABS_PRICE_BPS=2.0
ABS_MIN_BURST_USD=1000000
ABS_MIN_HITS=4
ABS_MAX_DISPLACEMENT_BPS=3.0
ABS_MIN_DOM_SHARE=0.55
ABS_MIN_EXCHANGES=2
ABS_EMIT_MIN_SCORE=55
